{
  "name": "lite-reminders",
  "version": "1.0.2",
  "description": "macOS Reminders integration with a lightweight, flash-note style interface.",
  "main": "main.js",
  "scripts": {
    "build": "npm run lint && node esbuild.config.mjs production && cp manifest.json styles.css dist/",
    "dev": "node esbuild.config.mjs",
    "deploy": "node deploy.mjs",
    "build-deploy": "npm run build && node deploy.mjs",
    "format": "prettier --write .",
    "lint": "eslint \"**/*.{ts,tsx}\"",
    "test": "echo \"No tests yet\"",
    "version": "node version-bump.mjs && git add manifest.json versions.json",
    "release": "node release.mjs"
  },
  "keywords": [
    "reminders",
    "tasks",
    "todo",
    "productivity"
  ],
  "author": "lizhifeng",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "esbuild": "^0.12.26",
    "eslint": "^9.39.4",
    "obsidian": "^1.4.16",
    "prettier": "^3.1.0",
    "tslib": "^2.6.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.2"
  }
}
